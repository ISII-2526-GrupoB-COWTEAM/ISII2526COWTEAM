  "components": {
    "schemas": {
      "DeviceForPurchaseDTO": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "name": {
            "type": "string",
            "nullable": true
          },
          "colour": {
            "type": "string",
            "nullable": true
          },
          "price": {
            "type": "number",
            "format": "double"
          },
          "model": {
            "type": "string",
            "nullable": true
          },
          "brand": {
            "type": "string",
            "nullable": true
          },
          "year": {
            "type": "integer",
            "format": "int32"
          }
        },
        "additionalProperties": false
      },
      "DeviceForRentalDTO": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "name": {
            "type": "string",
            "nullable": true
          },
          "brand": {
            "type": "string",
            "nullable": true
          },
          "color": {
            "type": "string",
            "nullable": true
          },
          "year": {
            "type": "integer",
            "format": "int32"
          },
          "model": {
            "type": "string",
            "nullable": true
          },
          "priceForRent": {
            "type": "number",
            "format": "double"
          }
        },
        "additionalProperties": false
      },
      "DeviceForReviewDTO": {
        "required": [
          "brand",
          "color",
          "id",
          "model",
          "name",
          "year"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "name": {
            "minLength": 1,
            "type": "string"
          },
          "brand": {
            "minLength": 1,
            "type": "string"
          },
          "color": {
            "minLength": 1,
            "type": "string"
          },
          "year": {
            "type": "integer",
            "format": "int32"
          },
          "model": {
            "minLength": 1,
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "PaymentMethodTypes": {
        "enum": [
          "CreditCard",
          "PayPal",
          "Cash"
        ],
        "type": "string"
      },
      "ProblemDetails": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "nullable": true
          },
          "title": {
            "type": "string",
            "nullable": true
          },
          "status": {
            "type": "integer",
            "format": "int32",
            "nullable": true
          },
          "detail": {
            "type": "string",
            "nullable": true
          },
          "instance": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": { }
      },
      "PurchaseDeviceDTO": {
        "required": [
          "brand",
          "color",
          "deviceId",
          "model",
          "name",
          "purchasePrice",
          "quantity",
          "year"
        ],
        "type": "object",
        "properties": {
          "deviceId": {
            "type": "integer",
            "format": "int32"
          },
          "name": {
            "minLength": 1,
            "type": "string"
          },
          "brand": {
            "minLength": 1,
            "type": "string"
          },
          "color": {
            "minLength": 1,
            "type": "string"
          },
          "year": {
            "type": "integer",
            "format": "int32"
          },
          "model": {
            "minLength": 1,
            "type": "string"
          },
          "purchasePrice": {
            "type": "number",
            "format": "double"
          },
          "quantity": {
            "type": "integer",
            "format": "int32"
          },
          "description": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "PurchaseForCreateDTO": {
        "required": [
          "deliveryAddress",
          "name",
          "paymentMethod",
          "surname"
        ],
        "type": "object",
        "properties": {
          "purchaseDevices": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/PurchaseDeviceDTO"
            },
            "nullable": true
          },
          "purchaseDate": {
            "type": "string",
            "format": "date-time"
          },
          "deliveryAddress": {
            "maxLength": 50,
            "minLength": 10,
            "type": "string",
            "format": "multiline"
          },
          "name": {
            "minLength": 1,
            "type": "string",
            "format": "email"
          },
          "surname": {
            "maxLength": 50,
            "minLength": 10,
            "type": "string"
          },
          "paymentMethod": {
            "$ref": "#/components/schemas/PaymentMethodTypes"
          },
          "TotalPrice": {
            "type": "number",
            "format": "double"
          }
        },
        "additionalProperties": false
      },
      "PurchaseForDetailDTO": {
        "required": [
          "deliveryAddress",
          "name",
          "paymentMethod",
          "surname"
        ],
        "type": "object",
        "properties": {
          "purchaseDevices": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/PurchaseDeviceDTO"
            },
            "nullable": true
          },
          "deliveryAddress": {
            "maxLength": 50,
            "minLength": 10,
            "type": "string",
            "format": "multiline"
          },
          "name": {
            "minLength": 1,
            "type": "string",
            "format": "email"
          },
          "surname": {
            "maxLength": 50,
            "minLength": 10,
            "type": "string"
          },
          "paymentMethod": {
            "$ref": "#/components/schemas/PaymentMethodTypes"
          },
          "TotalPrice": {
            "type": "number",
            "format": "double"
          },
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "purchaseDate": {
            "type": "string",
            "format": "date-time"
          }
        },
