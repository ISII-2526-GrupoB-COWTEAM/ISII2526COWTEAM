@page "/reviews/createreview"

@inject NavigationManager navigation
@using AppForSEII2526.Web.Components.Shared
@using AppForSEII2526.Web.API
@using Microsoft.AspNetCore.Authorization
@inject AppForSEII2526APIClient apiclient
@inject ILogger<CreateReview> logger
@inject ReviewStateContainer reviewState

<h3>Create Review</h3>

<EditForm Model="review" OnValidSubmit="OpenDialog">
    <div class="row">
        <DataAnnotationsValidator />
        <ValidationSummary class="row alert alert-danger" />
    </div>

    <div class="row alert alert-danger" role="alert" hidden="@hideErrors">
        <p id="ErrorsShown">Errors: @messageError</p>
    </div>

    <div class="row g-3">
        <div class="col-md">
            <div class="form-floating mb-3">
                <InputText @bind-Value="review.ReviewTitle" class="form-control" id="Title" />
                <label for="Title">Review Title</label>
            </div>
        </div>
        <div class="col-md">
            <div class="form-floating mb-3">
                <InputText @bind-Value="review.ApplicationUserName" class="form-control" id="UserName" />
                <label for="UserName">User Name</label>
            </div>
        </div>
        <div class="col-md">
             <div class="form-floating mb-3">
                <InputText @bind-Value="review.ApplicationUserCountry" class="form-control" id="Country" />
                <label for="Country">Country</label>
            </div>
        </div>
    </div>

     <div class="row g-3">
        <div class="col-md">
             <div class="form-floating">
                <button class="btn btn-primary" type="submit" id="Submit" disabled="@submitButtonDisabled">
                    Submit Review
                </button>
            </div>
        </div>
    </div>

    <h4>Review items</h4>
     <p>
        <button class="btn btn-outline-primary" type="button" @onclick="ModifyReviewDevices" id="ModifyDevices">
            Modify devices
        </button>
    </p>

    <div class="mh-100 table-responsive">
        <table class="table table-condensed table-hover" id="TableOf">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Model</th>
                    <th>Year</th>
                    <th>Rating (1-5)</th>
                    <th>Comments</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in review.ReviewItems)
                {
                    <tr id="DeviceData_@item.DeviceID">
                        <td>@item.Name</td>
                        <td>@item.Model</td>
                        <td>@item.Year</td>
                        <td>
                            <InputNumber @bind-Value="item.Rating" class="form-control" min="1" max="5" id="@($"rating_{item.DeviceID}")" />
                        </td>
                         <td>
                            <InputText @bind-Value="item.Comments" class="form-control" id="@($"comments_{item.DeviceID}")" />
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</EditForm>

@if (DialogIsOpen)
{
    <Dialog Caption="Submit Review"
            Message="Do you want to proceed to submit this review?"
            OnClose="@OnDialogClose"
            Type="Dialog.Category.SaveNot">
    </Dialog>
}

@code {
    private string messageError = "";
    private bool hideErrors => messageError.Length == 0;
    
    // Disable if no items
    private bool submitButtonDisabled => review.ReviewItems == null || review.ReviewItems.Count == 0;

    private bool DialogIsOpen;

    private ReviewForCreateDTO review => reviewState.Review;

    private void ModifyReviewDevices()
    {
        navigation.NavigateTo("/reviews/selectdevicesforreview");
    }

    private void OpenDialog()
    {
        DialogIsOpen = true;
    }

    private async Task OnDialogClose(bool isOk)
    {
        DialogIsOpen = false;

        if (isOk)
        {
            if (review.ReviewItems.Count > 0)
            {
                 // Basic validation
                 if (review.ReviewItems.Any(r => r.Rating < 1 || r.Rating > 5))
                 {
                      messageError = "Please ensure all items have a rating between 1 and 5.";
                      return;
                 }

                try
                {
                    var created = await apiclient.CreateReviewAsync(review);
                    reviewState.ReviewProcessed();
                    // Navigate back to select devices page - detail endpoint not available
                    navigation.NavigateTo("/reviews/selectdevicesforreview");
                }
                catch (ApiException<ValidationProblemDetails> apiexceptionvalidation)
                {
                    if (apiexceptionvalidation != null && apiexceptionvalidation.Result != null && apiexceptionvalidation.Result.Errors != null)
                    {
                        messageError = "";
                        foreach (var errors in apiexceptionvalidation.Result.Errors.Values)
                        {
                            messageError = string.Join("(*) ", messageError, string.Join(" (*) ", errors));
                        }
                    }
                    else 
                    {
                         messageError = "Validation error occurred.";
                    }
                }
                catch (ApiException ex)
                {
                    messageError = $"Error while processing your request: {ex.StatusCode}";
                }
                 catch (Exception ex)
                {
                    messageError = "Error while processing your request, please try again later!";
                }
            }
        }
    }
}
