@page "/purchases/createpurchase"

@inject NavigationManager navigation
@using AppForSEII2526.Web.Components.Shared
@using AppForSEII2526.Web.API
@using Microsoft.AspNetCore.Authorization
@inject AppForSEII2526APIClient apiclient
@inject ILogger<CreatePurchase> logger
@inject PurchaseStateContainer purchaseState



<h3>Create Purchase</h3>

@* purchase is the object that will be edited thanks to the form *@
<EditForm Model="purchase" OnValidSubmit="OpenDialog">
    <div class="row">
        <DataAnnotationsValidator />
        <ValidationSummary class="row alert alert-danger" />
    </div>

    <div class="row alert alert-danger" role="alert" hidden="@hideErrors">
        <p id="ErrorsShown">Errors: @messageError</p>
    </div>

    <div class="row g-3">
        <div class="col-md">
            <div class="form-floating mb-3">
                <InputText @bind-Value="purchase.Name" class="form-control" id="Name" />
                <label for="Name">Name</label>
            </div>
        </div>
        <div class="col-md">
            <div class="form-floating mb-3">
                <InputText @bind-Value="purchase.Surname" class="form-control" id="Surname" />
                <label for="Surname">Surname</label>
            </div>
        </div>
        <div class="col-md">
            <div class="form-floating mb-3">
                <InputText @bind-Value="purchase.DeliveryAddress" class="form-control" id="DeliveryAddress" />
                <label for="DeliveryAddress">Delivery Address</label>
            </div>
        </div>
    </div>

    <div class="row g-2">
        <div class="col-md">
            <div class="form-floating">
                @* Dropdown for selecting the payment method *@
                <InputSelect class="form-select" @bind-Value="purchase.PaymentMethod" id="PaymentMethod">
                    <option value="@PaymentMethodTypes.CreditCard" selected>CreditCard</option>
                    <option value="@PaymentMethodTypes.PayPal">PayPal</option>
                    <option value="@PaymentMethodTypes.Cash">Cash</option>
                </InputSelect>
                <label for="PaymentMethod">Payment Method</label>
            </div>
        </div>
        <div class="col-md">
            <div class="form-floating">
                @* Button to confirm the purchase of the selected devices *@
                <button class="btn btn-primary" type="submit" id="Submit" disabled="@purchaseButtonDisabled">
                    Purchase your devices
                </button>
            </div>
        </div>
    </div>

    <h4>Purchase detail</h4>
    <p>
        <b>Total price:</b> @TotalCost €
        <button class="btn btn-outline-primary" type="button" @onclick="ModifyPurchaseDevices" id="ModifyDevices">
            Modify devices
        </button>
    </p>

    <div class="mh-100 table-responsive">
        <table class="table table-condensed table-hover" id="TableOf">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Brand</th>
                    <th>Color</th>
                    <th>Year</th>
                    <th>Model</th>
                    <th>Price for Purchase</th>
                    <th>Quantity</th>
                    <th>Description</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in purchase.PurchaseDevices)
                {
                    <tr id="DeviceData_@item.DeviceId">
                        <td>@item.Name</td>
                        <td>@item.Brand</td>
                        <td>@item.Color</td>
                        <td>@item.Year</td>
                        <td>@item.Model</td>
                        <td>@item.PurchasePrice</td>
                        <td>@item.Quantity</td>
                        <td>
                            <InputText @bind-Value="item.Description"
                                       class="form-control"
                                       id="@($"description_{item.DeviceId}")" />
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</EditForm>

@* Modal popup dialog for checking if user wants to proceed to purchase *@
@if (DialogIsOpen)
{
    <Dialog Caption="Purchase devices"
            Message="Do you want to proceed to purchase the selected devices?"
            OnClose="@OnDialogClose"
            Type="Dialog.Category.SaveNot">
    </Dialog>
}

@code {
    private string messageError = "";
    private bool hideErrors => messageError.Length == 0;

    // purchase button will be disabled if there are no devices in the cart
    private bool purchaseButtonDisabled =>
        purchase.PurchaseDevices == null || purchase.PurchaseDevices.Count == 0;

    private bool DialogIsOpen;

    private decimal TotalCost
    {
        get
        {
            double price = purchase.PurchaseDevices.Sum(pd => pd.PurchasePrice * pd.Quantity);
            return Convert.ToDecimal(price);
        }
    }

    private void ModifyPurchaseDevices()
    {
        navigation.NavigateTo("/purchases/selectdevicesforpurchase");
    }

    private PurchaseForCreateDTO purchase => purchaseState.Purchase;

    private void OpenDialog()
    {
        DialogIsOpen = true;
    }

    private async Task OnDialogClose(bool isOk)
    {
        DialogIsOpen = false;

        if (isOk)
        {
            if (purchase.PurchaseDevices.Count > 0)
            {
                try
                {
                    var created = await apiclient.CreatePurchaseAsync(purchase);
                    purchaseState.PurchaseProcessed();
                    navigation.NavigateTo($"/purchases/detailpurchase/?PurchaseID={created.Id}");
                }
                catch (ApiException<ValidationProblemDetails> apiexceptionvalidation)
                {
                    if (apiexceptionvalidation.Result.Errors.Values != null)
                    {
                        messageError = "";
                        foreach (var errors in apiexceptionvalidation.Result.Errors.Values)
                        {
                            messageError = string.Join("(*) ", messageError, string.Join(" (*) ", errors));
                        }
                    }
                }
                catch (ApiException)
                {
                    // Inform user that there was some other error while processing the request
                    messageError = "Error while processing your request, please try again later!";
                }
            }
        }
    }

